<?xml version="1.0" encoding="UTF-8"?>

<plugin id="com.bank.ekyc.faceauth"
        version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>FaceAuthPlugin</name>
    <description>NPCI eKYC Face Authentication Plugin</description>

    <js-module src="www/faceauth.js" name="FaceAuthPlugin">
        <clobbers target="cordova.plugins.faceauth"/>
    </js-module>

    <engines>
        <engine name="cordova-android" version=">=10.0.0"/>
    </engines>

    <platform name="android">

        <config-file target="config.xml" parent="/*">
            <feature name="FaceAuthPlugin">
                <param name="android-package"
                       value="com.bank.faceauth.FaceAuthPlugin"/>
            </feature>
        </config-file>

        <source-file
            src="src/android/FaceAuthPlugin.java"
            target-dir="src/com/bank/faceauth"/>

        <source-file
            src="src/android/libs/ekyc-setu-sdk.aar"
            target-dir="libs"/>

        <framework
            src="src/android/faceauth.gradle"
            custom="true"
            type="gradleReference"/>

        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.CAMERA"/>
            <uses-permission android:name="android.permission.INTERNET"/>
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
        </config-file>

    </platform>

</plugin>
